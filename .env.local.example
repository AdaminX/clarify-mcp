# clarify-mcp local config. Copy to .env.local (gitignored).
#
# All values are OPTIONAL. The server works without any of them — auth is
# only needed if you want browser_open to start already logged in against a
# site that requires it.

# Origin of the app you'll inspect. Used by the form-login fallback when
# browser_open hits an auth redirect.
CLARIFY_DASHBOARD_URL=http://localhost:3000

# Credentials used by the auto-relogin path inside browser_open when the
# saved storageState (output/storage-state.json) has expired.
CLARIFY_EMAIL=
CLARIFY_PASSWORD=
