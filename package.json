{
  "name": "clarity-mcp",
  "version": "0.1.0",
  "description": "Local MCP server that lets Claude inspect a webpage's console, network, DOM, and screen state while debugging — disposable headless Chromium, no live profile access, every call logged.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "playwright",
    "browser",
    "devtools",
    "debugging"
  ],
  "license": "MIT",
  "author": "AdaminX",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdaminX/clarity-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/AdaminX/clarity-mcp/issues"
  },
  "homepage": "https://github.com/AdaminX/clarity-mcp#readme",
  "type": "module",
  "bin": {
    "clarity-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    ".env.local.example"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "smoke": "node scripts/smoke.mjs",
    "inspect": "node scripts/inspect.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
